<Window
    x:Class="ToolboxInstaller.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ToolboxInstaller"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="512"
    Height="394"
    ResizeMode="CanMinimize"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="6.5*" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <local:StartPage x:Name="Test" Grid.Row="0" />
        <StackPanel Grid.Row="1" Background="#F0F0F0">
            <Separator VerticalAlignment="Top" />
            <WrapPanel Margin="0,7,20,0" HorizontalAlignment="Right">
                <Button
                    x:Name="BackButton"
                    Width="75"
                    Margin="10,0,0,0">
                    Back
                </Button>
                <Button
                    x:Name="NextButton"
                    Width="75"
                    Margin="5,0,0,0">
                    Next
                </Button>
                <Button
                    x:Name="CancelButton"
                    Width="75"
                    Margin="20,0,0,0">
                    Cancel
                </Button>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>
